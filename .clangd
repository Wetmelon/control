---
CompileFlags:
    Remove: [-fcoroutines, -fconcepts-diagnostics-depth=3, -fconstexpr-ops-limit=*]
    Add: ['-fconstexpr-steps=100000000']

Diagnostics:
    UnusedIncludes: Strict
    Suppress: ['constexpr_var_requires_const_init', 'invalid_consteval_call']

Documentation:
  CommentFormat: Doxygen
  